# Azure OpenAI Configuration
# API key for authenticating with Azure OpenAI Service
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Full endpoint URL for your Azure OpenAI resource (e.g., https://your-resource.openai.azure.com)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Name of the deployed model in Azure OpenAI Studio (e.g., gpt-4o, gpt-35-turbo)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure OpenAI API version to use (e.g., 2024-02-15-preview)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Authentication
# Secret key used for signing and verifying JWT tokens — use a strong random string (min 32 chars)
JWT_SECRET=your-jwt-secret-min-32-characters-long

# Salesforce Integration
# OAuth2 Connected App client ID from Salesforce
SALESFORCE_CLIENT_ID=your-salesforce-client-id

# OAuth2 Connected App client secret from Salesforce
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret

# Salesforce instance URL (e.g., https://yourorg.my.salesforce.com)
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com

# Salesforce OAuth2 access token for API calls (can be obtained via OAuth flow)
SALESFORCE_ACCESS_TOKEN=your-salesforce-access-token

# Application
# Public-facing URL of the application (used for links in notifications and CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SLA & Priority Configuration
# Number of minutes before a DM is considered to have breached the SLA response time
SLA_BREACH_MINUTES=30

# Confidence score threshold (0-100) at or above which a lead is classified as high priority
HIGH_PRIORITY_THRESHOLD=80

# Notifications
# Email address used as the "From" sender for outbound notification emails
NOTIFICATION_EMAIL_FROM=noreply@example.com